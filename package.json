{
  "name": "generate-unicorn-next",
  "private": true,
  "engines": {
    "node": ">=20 <26",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node UNICORN_FINAL/src/index.js",
    "build": "npm --prefix UNICORN_FINAL run lint && npm --prefix UNICORN_FINAL test",
    "start": "node UNICORN_FINAL/src/index.js",
    "unicorn:start": "node UNICORN_FINAL/src/index.js",
    "unicorn:test": "npm --prefix UNICORN_FINAL test",
    "lint": "npm --prefix UNICORN_FINAL run lint",
    "unicorn:lint": "npm --prefix UNICORN_FINAL run lint",
    "deploy": "npm --prefix UNICORN_FINAL run deploy:full",
    "heal": "npm --prefix UNICORN_FINAL run health:guardian",
    "health:global": "node scripts/global-health-probe.js",
    "secrets:doctor": "node scripts/secrets-doctor.js",
    "secrets:bootstrap": "node -e \"require('./UNICORN_FINAL/src/config/secrets.js').bootstrap({log:true,persistGenerated:false})\"",
    "ssh:bootstrap": "bash UNICORN_FINAL/scripts/bootstrap-ssh-via-github.sh",
    "evolve": "npm --prefix UNICORN_FINAL run innovation:sprint",
    "test": "npm --prefix UNICORN_FINAL test"
  },
  "dependencies": {
    "@wasmer/wasi": "^1.2.2",
    "axios": "^1.16.1",
    "iltorb": "^2.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "yaml": "^2.8.4"
  }
}
