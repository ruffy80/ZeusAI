# DeepSeek Advisory Loop — systemd unit
#
# Auto-installed by `deploy.yml` on every push to main (step
# “🧠 Install + start DeepSeek advisory/execute loop (default-OFF)”).
# A manual fallback also exists: the `🛠️ Install DeepSeek Loop (Hetzner)`
# workflow (`.github/workflows/install-deepseek-loop.yml`) can install,
# uninstall, or report status on demand (workflow_dispatch).
#
# After install, the loop is still default-OFF: the script exits 0 unless
# `DEEPSEEK_LOOP_ENABLED=1` is set in the EnvironmentFile. To actually run,
# either:
#   1. Set DEEPSEEK_LOOP_ENABLED=1 + DEEPSEEK_API_KEY (+ DEEPSEEK_LOOP_EXECUTE=1
#      + DEEPSEEK_LOOP_ADMIN_TOKEN for execute mode) as repository secrets in
#      GitHub Actions — `create-env.sh` propagates them to `.env` on next
#      deploy and the install step then runs `systemctl enable --now`.
#   2. Or, manually on the box: edit /var/www/unicorn/UNICORN_FINAL/.env then
#      `systemctl enable --now deepseek-loop.service`
#
# Safety:
#   * Default-OFF gate inside the script (`DEEPSEEK_LOOP_ENABLED=1` required).
#   * Execute mode additionally requires DEEPSEEK_LOOP_EXECUTE=1 and
#     DEEPSEEK_LOOP_ADMIN_TOKEN. Without both it is advisory only (log).
#   * Restart=on-failure (NOT always) so that a clean `exit 0` from the
#     default-OFF gate does NOT cause a tight restart loop while disabled.

[Unit]
Description=DeepSeek Advisory Loop (allowlist-only, default-off)
After=network.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/var/www/unicorn/UNICORN_FINAL/.env
WorkingDirectory=/var/www/unicorn/UNICORN_FINAL
ExecStart=/usr/bin/node /var/www/unicorn/UNICORN_FINAL/scripts/deepseek-loop.js
Restart=on-failure
RestartSec=60

# Hardening — defense in depth.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/www/unicorn/UNICORN_FINAL/data/logs
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictSUIDSGID=true
RestrictRealtime=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM

# Logging goes to journalctl + the per-script log file under
# /var/www/unicorn/UNICORN_FINAL/data/logs/deepseek-loop.log
# (override via DEEPSEEK_LOOP_LOG_PATH in the EnvironmentFile).
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
