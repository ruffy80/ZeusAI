NODE_ENV=development
PORT=3000
ADMIN_SECRET=VLADOI_IONUT_SECRET_SUPREM_2026
JWT_SECRET=change-me-to-a-long-random-secret-in-production
SESSION_SECRET=change-me-to-a-long-random-session-secret-in-production

# ==================== DEEPSEEK — MOD AUTONOM PUTERE MAXIMĂ ====================
DEEPSEEK_API_KEY=your_deepseek_api_key_here        # <--- pune cheia reală aici pentru autonomie totală
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_LOOP_ENABLED=1                            # <--- PORNEȘTE automat pe server!
DEEPSEEK_LOOP_EXECUTE=1                            # <--- EXECUTĂ (nu doar recomandă)!
DEEPSEEK_LOOP_ADMIN_TOKEN=your_admin_jwt_here      # <--- token admin puternic
DEEPSEEK_LOOP_INTERVAL_MS=60000                    # <--- la 60s, optimizează după nevoie

# ==================== AUTH GUARDIAN (permanent auth protection) ====================
AUTH_GUARDIAN_ENABLED=1
AUTH_GUARDIAN_TEST_EMAIL=auth.guardian@zeusai.pro
AUTH_GUARDIAN_TEST_PASSWORD=change-me-strong-passphrase
AUTH_GUARDIAN_TEST_NAME=AuthGuardian
AUTH_GUARDIAN_INTERVAL_MS=300000
AUTH_GUARDIAN_REPAIR_WINDOW_MS=30000
AUTH_GUARDIAN_BACKUP_KEEP=24
AUTH_GUARDIAN_ALERT_WEBHOOK=

