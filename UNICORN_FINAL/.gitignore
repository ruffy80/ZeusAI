.DS_Store
.env
node_modules/
.vercel/
.vercel

logs/
*.local
data/*.db
data/*.db-shm
data/*.db-wal
data/runtime-secrets.json
data/**/*.secret
data/**/secrets*.json
# Sovereign-commerce runtime state (orders, signing key, catalog-seen, txid cache)
data/commerce/
# Owner notifications (audit log written at runtime — not committed)
data/notifications.jsonl

# Generated innovation/autonomous cycle JSON files (auto-created at runtime)
generated/innovation_*.json
generated/autonomous-cycle-*.json
generated/AUTONOMOUS-STATUS.json
generated/AUTONOMOUS-STATUS.md

# frontier signing keys (NEVER commit)
data/frontier/*.key.pem
data/frontier/*.pub.pem

# Test- and runtime-generated artefacts that must NEVER reach git (they are
# already excluded from the rsync deploy via deploy.yml, but they should not
# show up in commits either — they're per-process state, not source).
backups/
data/marketing/
data/money-machine/
data/outbox/
data/world-standard/
data/perf/
data/value-proof/
data/revenue/
