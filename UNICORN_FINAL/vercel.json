{
  "version": 2,
  "name": "zeusai",
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["backend/**", "src/**", "generated/**"]
      }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)",    "dest": "/backend/index.js" },
    { "src": "/deploy",      "dest": "/backend/index.js" },
    { "src": "/health",      "dest": "/backend/index.js" },
    { "src": "/snapshot",    "dest": "/backend/index.js" },
    { "src": "/stream",      "dest": "/backend/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",        "dest": "/backend/index.js" }
  ],
  "env": {
    "NODE_ENV": "production",
    "PUBLIC_APP_URL": "https://zeusai.pro",
    "SITE_DOMAIN": "zeusai.pro",
    "BTC_WALLET_ADDRESS": "bc1q4f7e66z87mdfj56kz0dj5hvcnpmh0qh4wuv22e",
    "OWNER_NAME": "Vladoi Ionut",
    "OWNER_EMAIL": "vladoi_ionut@yahoo.com"
  }
}
