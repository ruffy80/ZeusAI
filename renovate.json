{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":semanticCommitTypeAll(chore)",
    ":maintainLockFilesWeekly",
    ":timezone(Europe/Bucharest)"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "schedule": ["before 6am on monday"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 8,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false,
      "groupName": "npm minor+patch"
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"],
      "dependencyDashboardApproval": true
    },
    {
      "matchPackageNames": [
        "stripe",
        "express",
        "helmet",
        "@simplewebauthn/server",
        "bcryptjs",
        "jsonwebtoken",
        "libsodium-wrappers",
        "@noble/hashes",
        "@noble/post-quantum",
        "secrets.js-grempe"
      ],
      "addLabels": ["security-sensitive"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "description": "Security-sensitive packages always need explicit human review before update."
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["github-actions"],
      "groupName": "github-actions"
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/build_mirror/**",
    "release/**",
    "UNICORN_FINAL.zip"
  ]
}
