{
  "version": 2,
  "name": "zeusai",
  "builds": [
    {
      "src": "UNICORN_FINAL/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "UNICORN_FINAL/backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",             "dest": "/UNICORN_FINAL/backend/index.js" },
    { "src": "/health",               "dest": "/UNICORN_FINAL/src/index.js" },
    { "src": "/snapshot",             "dest": "/UNICORN_FINAL/src/index.js" },
    { "src": "/stream",               "dest": "/UNICORN_FINAL/src/index.js" },
    { "src": "/innovation(.*)",       "dest": "/UNICORN_FINAL/src/index.js" },
    { "src": "/modules(.*)",          "dest": "/UNICORN_FINAL/src/index.js" },
    { "src": "/(.*)",                 "headers": { "cache-control": "no-store,no-cache,must-revalidate" }, "dest": "/UNICORN_FINAL/src/index.js" }
  ],
  "env": {
    "NODE_ENV": "production",
    "PUBLIC_APP_URL": "https://zeusai.pro",
    "SITE_DOMAIN": "zeusai.pro",
    "BTC_WALLET_ADDRESS": "bc1q4f7e66z87mdfj56kz0dj5hvcnpmh0qh4wuv22e",
    "OWNER_NAME": "Vladoi Ionut",
    "OWNER_EMAIL": "vladoi_ionut@yahoo.com"
  }
}
